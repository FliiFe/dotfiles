set page-padding 10
set adjust-open width
set recolor true
set font "Source Code Pro normal 11"
set recolor-lightcolor "#0f0f0f"
set recolor-keephue true
set completion-bg "#0f0f0f"
set inputbar-bg "#0f0f0f"
set statusbar-bg "#0f0f0f"
set smooth-scroll true
set show-v-scrollbar true
set window-title-home-tilde true

map t exec 'compton-trans -c 100'
map <C-t> exec 'compton-trans -c 70'
