[bar/first]
monitor = DisplayPort-0
monitor-strict = false

fixed-center = true

; Dimension defined as pixel value (e.g. 35) or percentage (e.g. 50%)
width = 100%
height = 25

; Background argb color (e.g. #f00, #ff992a, #ddff1023)
; background = #d80f0f0f
background = #b30f0f0f

; Foreground argb color (e.g. #f00, #ff992a, #ddff1023)
foreground = #00000000

radius = 1.0

line-size = 2
line-color = #f00

padding = 0

module-margin = 2

font-0 = Roboto:size=10;3
font-1 = NotoSansSymbols:size=10;3
font-2 = FontAwesome:size=14;5
font-3 = NotoEmoji:size=10;2
font-4 = DejaVu Sans:size=10;0

modules-left = i3wm title
modules-center = weather
modules-right = cpu volume date clock

; The separator will be inserted between the output of each module
separator = 

; Opacity value between 0.0 and 1.0 used on fade in/out
dim-value = 1.0

wm-name = i3

tray-position = right
tray-maxsize = 16
tray-background = ${root.background}
tray-padding = 10
tray-scale = 1.0

enable-ipc = false

[bar/second]
inherit = bar/first
monitor = HDMI-A-0

[bar/third]
inherit = bar/first
monitor = DVI-I-1
; background = #ff111111

[module/cpu]
type = internal/cpu
interval = 0.5
format = <ramp-coreload>
format-foreground = #999

ramp-coreload-0 = ▁
ramp-coreload-1 = ▂
ramp-coreload-2 = ▃
ramp-coreload-3 = ▄
ramp-coreload-4 = ▅
ramp-coreload-5 = ▆
ramp-coreload-6 = ▇
ramp-coreload-7 = █

[module/weather]
type = custom/script
interval = 300
format = <label>
format-foreground = #dadada
format-underline = #999
format-padding = 3
exec = ~/.config/polybar/weather

[module/clock]
type = internal/date
format = 🕓 <label>
format-foreground = #fff
format-underline = #fff
format-padding = 2
interval = 1
date = %H:%M:%S

[module/date]
type = internal/date
interval = 10
date = %d-%m-%Y
format = 📆  <label>
format-foreground = #888

[module/i3wm]
type = internal/i3

pin-workspaces = true
index-sort = true
enable-click = true
enable-scroll = false
wrapping-scroll = true
reverse-scroll = false

format = <label-state> <label-mode>

label-mode = %mode%-mode
label-mode-padding = 1
label-mode-foreground = #dadada

label-focused = %index%
label-focused-foreground = #dadada
label-focused-background = #b82a2a2a
label-focused-underline = #dadada
label-focused-padding = 4

label-unfocused = %index%
label-unfocused-padding = 4
label-unfocused-foreground = #999999

label-visible = %index%
label-visible-padding = 4
label-visible-foreground = #dadada
label-visible-background = #b82a2a2a
label-visible-underline = #dadada

label-urgent = %index%
label-urgent-foreground = #1c1c1c
label-urgent-background = #b8df5f5f
label-urgent-padding = 4

[module/volume]
type = internal/volume

format-volume = 
format-volume-padding = 0
format-volume-foreground = #a0a0a0

format-muted = 
format-muted-padding = 1
format-muted-foreground = #888

[module/title]
type = internal/xwindow
format-foreground = #999

