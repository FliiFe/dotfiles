[bar/first]
fixed-center = true

; Dimension defined as pixel value (e.g. 35) or percentage (e.g. 50%)
width = 100%
height = 25

; Background argb color (e.g. #f00, #ff992a, #ddff1023)
; background = #d80f0f0f
background = #990f0f0f

; Foreground argb color (e.g. #f00, #ff992a, #ddff1023)
foreground = #00000000

radius = 1.0

line-size = 2
line-color = #f00

padding = 0

module-margin = 2

font-0 = Roboto:size=10;3
font-1 = Material Icons:size=14;5
font-2 = DejaVu Sans:size=12;3
font-3 = NotoSansSymbols:size=10;3
font-4 = NotoEmoji:pixelsize=10;10

modules-left = i3wm title
modules-center = weather
modules-right = spotify battery charging date clock pulseaudio

; Opacity value between 0.0 and 1.0 used on fade in/out
dim-value = 1.0

wm-name = i3

tray-position = right
tray-maxsize = 16
; tray-background = #2D403B
; tray-background = #0B383C
; tray-background = #283131
tray-background = #b30f0f0f
tray-padding = 10
tray-scale = 1.0

enable-ipc = false

[module/battery]
type = custom/script
interval=10

format = <label>
format-foreground = #dadada
format-padding = -1
exec = ~/.config/polybar/battery

[module/charging]
type = custom/script
interval = 2

format = <label>
format-foreground = #a0a0a0
format-padding = -1
exec = ~/.config/polybar/charging

[module/cpu]
type = internal/cpu
interval = 0.5
format = <ramp-coreload>
format-foreground = #999

ramp-coreload-0 = ▁
ramp-coreload-1 = ▂
ramp-coreload-2 = ▃
ramp-coreload-3 = ▄
ramp-coreload-4 = ▅
ramp-coreload-5 = ▆
ramp-coreload-6 = ▇
ramp-coreload-7 = █

[module/weather]
type = custom/script
interval = 300
format = <label>
format-foreground = #dadada
format-underline = #999
format-padding = 3
exec = ~/.config/polybar/weather

[module/clock]
type = internal/date
; format = 🕤 <label>
format =  <label>
; format = <label>
format-foreground = #fff
format-underline = #fff
format-padding = 2
interval = 1
date = %H:%M:%S

[module/date]
type = internal/date
interval = 10
date = %d-%m-%Y
format =   <label>
format-foreground = #888

[module/i3wm]
type = internal/i3

pin-workspaces = true
index-sort = true
enable-click = true
enable-scroll = false
wrapping-scroll = true
reverse-scroll = false

format = <label-state> <label-mode>

label-mode = %mode%-mode
label-mode-padding = 1
label-mode-foreground = #dadada

label-focused = %index%
label-focused-foreground = #dadada
label-focused-background = #b82a2a2a
label-focused-underline = #dadada
label-focused-padding = 4

label-unfocused = %index%
label-unfocused-padding = 4
label-unfocused-foreground = #999999

label-visible = %index%
label-visible-padding = 4
label-visible-foreground = #dadada
label-visible-background = #b82a2a2a
label-visible-underline = #dadada

label-urgent = %index%
label-urgent-foreground = #1c1c1c
label-urgent-background = #b8df5f5f
label-urgent-padding = 4

[module/pulseaudio]
type = internal/pulseaudio

; Sink to be used, if it exists (find using `pacmd list-sinks`, name field)
; If not, uses default sink
sink = alsa_output.pci-0000_00_1f.3.analog-stereo

; Use PA_VOLUME_UI_MAX (~153%) if true, or PA_VOLUME_NORM (100%) if false
; Default: true
use-ui-max = false

; Interval for volume increase/decrease (in percent points)
; Default: 5
interval = 5

label-volume-foreground = #fff
ramp-volume-foreground = #fff

; Available tags:
;   <label-volume> (default)
;   <ramp-volume>
;   <bar-volume>
format-volume = <ramp-volume> <label-volume>

; Available tags:
;   <label-muted> (default)
;   <ramp-volume>
;   <bar-volume>
;format-muted = <label-muted>

; Available tokens:
;   %percentage% (default)
;label-volume = %percentage%%

; Available tokens:
;   %percentage% (default)
label-muted =  0%
label-muted-foreground = #666

; Only applies if <ramp-volume> is used
ramp-volume-0 = 
ramp-volume-1 = 
ramp-volume-2 = 

[module/volume]
type = internal/volume

format-volume = 
format-volume-padding = 0
format-volume-foreground = #a0a0a0

format-muted = 
; format-muted = 
format-muted-padding = 1
format-muted-foreground = #888

[module/title]
type = internal/xwindow
format-foreground = #999
label-maxlen = 50

[module/spotify]
type = custom/script
interval = 1
format-prefix = " "
format-foreground = #fafafa
format-padding = 2
format = <label>
exec = ~/.config/polybar/spotify_status.py -f '{artist} - {song}'
format-underline = #1db954

; vim: ft=dosini:foldmethod=manual:
