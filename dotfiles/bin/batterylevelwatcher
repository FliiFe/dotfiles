#!/bin/fish

set BAT_LOW 5
set BAT_HIGH 95

while true
    set BAT_LEVEL (battery)
    test "$BAT_LEVEL" -eq $BAT_LOW
    and not on_ac_power
    and notify-send --icon=$HOME/.config/battery_icons/battery_critical.png 'Niveau de batterie critique !' 'Le niveau de batterie est inférieur à '$BAT_LOW%
    and sleep 100;
    test "$BAT_LEVEL" -eq $BAT_HIGH
    and on_ac_power
    and notify-send --icon=$HOME/.config/battery_icons/battery_full_charging.png 'Batterie chargée' 'Le niveau de batterie a atteint '$BAT_HIGH%
    and sleep 100
    test "$BAT_LEVEL" -eq 1
    and not on_ac_power
    and sudo pm-suspend-hybrid
    and sleep 100
    sleep 5
end
