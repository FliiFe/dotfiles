#!/usr/bin/env fish

# Suspend dunst
pkill -u "$USER" -USR1 dunst

i3lock -n -k \
    --image=$HOME/.bg.lock.png -t \
    --timecolor=eeeeeeee \
    --time-font='Roboto Thin' \
    --datecolor=eeeeeeee \
    --indicator \
    --timesize=75 \
    --timepos=160:85 \
    -S=0 \
    --datesize=1 \
    --datestr="" \
    --insidecolor=55555500 \
    --ringcolor=ffffff00 \
    --line-uses-inside \
    --radius 350 \
    --separator=00000000 \
    --keyhlcolor=ffffff10 \
    --bshlcolor=ffffff20 \
    --ringwrongcolor=ffffff00 \
    --ringvercolor=ffffff00 \
    --insidevercolor=55555500 \
    --veriftext=… \
    --wrongtext="Error !" \
    --insidewrongcolor=f2777a00 \
    --ringwrongcolor=ffffff00 \
    --verifcolor=ffffff00 \

# Resume dunst
pkill -u "$USER" -USR2 dunst
