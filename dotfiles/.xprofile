#!/bin/sh

# Set the background
# sh ~/.fehbg &
# Pause as compose key
setxkbmap fr -option compose:paus &
eval $(/usr/bin/gnome-keyring-daemon --start --components=pkcs11,secrets,ssh,gpg)
export SSH_AUTH_SOCK
