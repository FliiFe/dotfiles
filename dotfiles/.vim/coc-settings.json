{
    "languageserver": {
        "ocaml": {
            "command": "ocamllsp",
            "filetypes": [
                "ocaml"
            ]
        },
        "dockerfile": {
            "command": "docker-langserver",
            "filetypes": [
                "dockerfile"
            ],
            "args": [
                "--stdio"
            ]
        },
        "haskell": {
            "command": "ghcide",
            "rootPatterns": [
                "stack.yaml",
                "*.cabal"
            ],
            "filetypes": [
                "hs",
                "lhs",
                "haskell"
            ],
            "initializationOptions": {},
            "args": [
                "--lsp"
            ]
        },
        "lean": {
            "command": "node",
            "filetypes": [
                "lean"
            ],
            "args": [
                "/home/fliife/.npm-global/bin/lean-language-server",
                "--stdio"
            ]
        }
    },
    "coc.source.omni.filetypes": [
        "tex"
    ]
}
